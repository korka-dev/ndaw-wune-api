# ══════════════════════════════════════════════════════════════
#  NDAW WUNE — Configuration DÉVELOPPEMENT LOCAL
#  Utilisé uniquement par ./start.sh (jamais en production)
# ══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────
APP_NAME=ARED-NdawWune
APP_ENV=development

# Même clé que prod pour ne pas régénérer les tokens JWT
SECRET_KEY=88a3340d667dc09de75e0cbaf02fa571b947aaf3282afb718ee0f330cb3c745ba5a8caccdf4df5e34bd33e3fc88993611c10228e30df15fdb82b55031f91c1e8

# CORS : dashboard local + Expo mobile
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://127.0.0.1:3000,http://127.0.0.1:8081

MAX_CONNECTIONS_POOL=10
SYNC_CACHE_TTL_SECONDS=300

# ── PostgreSQL (conteneur Docker local) ───────────────────────
POSTGRES_DB=ared_ndawune
POSTGRES_USER=ared_user
POSTGRES_PASSWORD=ared_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis (conteneur Docker local) ────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── URLs construites (lues par FastAPI et docker-compose) ─────
DATABASE_URL=postgresql+asyncpg://ared_user:ared_secret@db:5432/ared_ndawune
REDIS_URL=redis://redis:6379/0
