# ────────────────────────────────────────────────────────────────────────────
# Copiez ce fichier en .env et remplissez vos valeurs.
# Ne commitez JAMAIS le fichier .env dans git.
# ────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=ARED-NdawWune
# Générer avec : python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

# Origines autorisées pour le CORS (séparées par virgule)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Taille du pool de connexions SQLAlchemy
MAX_CONNECTIONS_POOL=20

# Durée du cache de synchronisation offline (en secondes)
# 300 = 5 min : filet de sécurité si l'invalidation Redis échoue
SYNC_CACHE_TTL_SECONDS=300

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=ared_ndawune
POSTGRES_USER=ared_user
POSTGRES_PASSWORD=
POSTGRES_HOST=db        # "db" en Docker, "localhost" en développement local
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis        # "redis" en Docker, "localhost" en développement local
REDIS_PORT=6379
REDIS_DB=0

# ── URLs construites automatiquement ──────────────────────────────────────────
# Ces deux variables sont interpolées depuis les variables ci-dessus.
# En développement local, remplacez POSTGRES_HOST=localhost et REDIS_HOST=localhost.
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}
